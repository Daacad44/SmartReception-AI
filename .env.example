# Copy to .env and fill in real values (.env is gitignored — never commit secrets)

# Database (Supabase PostgreSQL)
# Use pooler URL for serverless (port 6543), direct URL for migrations (port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=3&pool_timeout=20
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Optional overrides (also auto-applied on Vercel when omitted from DATABASE_URL)
DATABASE_CONNECTION_LIMIT=3
DATABASE_POOL_TIMEOUT=20

# Supabase
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
AI_REPLY_ENABLED=true
AI_REPLY_TIMEOUT_MS=5000

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_BUSINESS=price_your_business_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# WhatsApp Cloud API (Meta) — WHATSAPP_VERIFY_TOKEN takes priority over VERIFY_TOKEN
WHATSAPP_VERIFY_TOKEN=smartreception-verify
VERIFY_TOKEN=smartreception-verify
WHATSAPP_WEBHOOK_URL=https://api.somreception.botandev.com/api/v1/webhooks/whatsapp
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WHATSAPP_APP_SECRET=your-whatsapp-app-secret
WHATSAPP_API_VERSION=v23.0

# WhatsApp Embedded Signup (OAuth "Connect with Facebook" onboarding).
# Create/enable this in Meta Developer Console → your App → WhatsApp →
# Embedded Signup, then paste the Configuration ID here. Without this set,
# the Settings page falls back to manual credential entry only.
META_WHATSAPP_CONFIG_ID=your-embedded-signup-config-id

# Cloudflare R2 — primary object store post-Supabase migration.
# One R2 account, two buckets (both private): one for knowledge-base docs,
# one for WhatsApp inbound media. Signed URLs are generated server-side.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Bucket for knowledge documents (PDF/DOCX/TXT). If R2_KNOWLEDGE_BUCKET is
# unset, R2_BUCKET_NAME is used for backward compatibility with older configs.
R2_BUCKET_NAME=knowledge-documents
R2_KNOWLEDGE_BUCKET=knowledge-documents
R2_WHATSAPP_MEDIA_BUCKET=whatsapp-media
# Optional: only set if you've fronted the R2 bucket with a public custom
# domain and want URLs to point at that instead of signed private URLs.
R2_PUBLIC_URL=

# Frontend (Vite)
# VITE_API_URL also derives the realtime WebSocket URL (see
# apps/frontend/src/lib/realtime-client.ts) — same origin, ws(s):// scheme,
# path /realtime appended.
VITE_API_URL=/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://somreception.botandev.com
API_URL=https://api.somreception.botandev.com

# Email (Resend — production)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_NAME=SmartReception AI
EMAIL_FROM_ADDRESS=noreply@botandev.com
EMAIL_SUPPORT=support@botandev.com

# Email (SMTP fallback — optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SmartReception AI <noreply@botandev.com>
