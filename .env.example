# Copy to .env and fill in real values (.env is gitignored — never commit secrets)

# Database (Supabase PostgreSQL)
# Use pooler URL for serverless (port 6543), direct URL for migrations (port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_BUSINESS=price_your_business_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# WhatsApp Cloud API (Meta)
VERIFY_TOKEN=smartreception-verify
WHATSAPP_VERIFY_TOKEN=smartreception-verify
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WHATSAPP_APP_SECRET=your-whatsapp-app-secret
WHATSAPP_API_VERSION=v21.0

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=smartreception
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Frontend (Vite)
VITE_API_URL=/api/v1
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://somreception.botandev.com
API_URL=https://somreception.botandev.com
WHATSAPP_WEBHOOK_URL=https://somreception.botandev.com/webhook

# Email (Resend — production)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_NAME=SmartReception AI
EMAIL_FROM_ADDRESS=noreply@botandev.com
EMAIL_SUPPORT=support@botandev.com

# Email (SMTP fallback — optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SmartReception AI <noreply@botandev.com>
