DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.hlngecipthlecwqozwhe.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://hlngecipthlecwqozwhe.supabase.co
