  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, isActive])
  @@map("services")
}

model Appointment {
  id                     String              @id @default(uuid())
  businessId             String
  customerId             String
  serviceId              String?
  assignedToId           String?
  createdById            String?
  workflowId             String?
  workflowStageId        String?
  workflowStageKey       String?
  bookingNumber          String?
  qrCodeData             String?
  icsContent             String?
  calendarEventId        String?
  location               String?
  primaryPhone           String?
  secondaryPhone         String?
  guardianPhone          String?
  companyPhone           String?
  primaryEmail           String?
  secondaryEmail         String?
  guardianEmail          String?
  businessEmail          String?
  title                  String
  description            String?
  serviceRequested       String?
  serviceCategory        String?
  companyName            String?
  additionalNotes        String?
  requirementsCollected  Json?
  aiConversationSummary  Json?
  budget                 Decimal?            @db.Decimal(12, 2)
  leadSource             String?             @default("WHATSAPP")
  meetingLink            String?
  priority               AppointmentPriority @default(MEDIUM)
  startTime              DateTime
  endTime                DateTime
  status                 AppointmentStatus   @default(SCHEDULED)
  rejectionReason        String?
  notes                  String?
  reminderSent           Boolean             @default(false)
  reminder24hSent        Boolean             @default(false)
  reminder1hSent         Boolean             @default(false)
  reminder15mSent        Boolean             @default(false)
  reminder30mSent        Boolean             @default(false)
  reminder20mSent        Boolean             @default(false)
  reminder10mSent        Boolean             @default(false)
  followUp24hSent        Boolean             @default(false)
  missedNotificationSent Boolean             @default(false)
  confirmationSentAt     DateTime?
  missedAt               DateTime?
  canRebookAfter         DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service       Service?                  @relation(fields: [serviceId], references: [id])
  assignedTo    User?                     @relation("AssignedStaff", fields: [assignedToId], references: [id])
  createdBy     User?                     @relation("AppointmentCreator", fields: [createdById], references: [id])
  workflow      AppointmentWorkflow?      @relation(fields: [workflowId], references: [id])
  workflowStage AppointmentWorkflowStage? @relation(fields: [workflowStageId], references: [id])
  internalNotes AppointmentInternalNote[]
  notifications AppointmentNotification[]
  timelineEvents AppointmentTimelineEvent[]
  workflowExecutions AppointmentWorkflowExecution[]

  @@index([businessId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([businessId, workflowStageKey])
  @@index([businessId, bookingNumber])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([workflowId])
  @@index([priority])
  @@map("appointments")
}

model AppointmentInternalNote {
  id            String   @id @default(uuid())
