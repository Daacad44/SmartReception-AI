// ─── ENTERPRISE SUBSCRIPTION & LICENSE ───────────────────────────────────────

model SubscriptionPlanCatalog {
  id                   String           @id @default(uuid())
  code                 SubscriptionPlan @unique
  name                 String
  description          String?
  features             Json?
  featureFlags         Json?
  monthlyPrice         Decimal          @default(0) @db.Decimal(10, 2)
  yearlyPrice          Decimal          @default(0) @db.Decimal(10, 2)
  maxUsers             Int              @default(1)
  maxConversations     Int              @default(100)
  maxWhatsappNumbers   Int              @default(1)
  maxAiAgents          Int              @default(1)
  storageLimitMb       Int              @default(512)
  knowledgeBaseLimit   Int              @default(1)
  teamLimit            Int              @default(1)
  campaignLimit        Int              @default(0)
  appointmentLimit     Int              @default(50)
  sortOrder            Int              @default(0)
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  businessSubscriptions BusinessSubscription[]
  history               SubscriptionHistory[]

  @@map("subscription_plans")
}

model BusinessSubscription {
  id                String                     @id @default(uuid())
  businessId        String                     @unique
  planId            String
  previousPlanId    String?
  status            BusinessLicenseStatus      @default(PENDING)
  durationPreset    SubscriptionDurationPreset?
  durationDays      Int?
  activatedAt       DateTime?
  expiresAt         DateTime?
  pausedAt          DateTime?
  cancelledAt       DateTime?
  lockedAt          DateTime?
  isPaused          Boolean                    @default(false)
  isTrial           Boolean                    @default(false)
  internalNotes     String?
  paymentStatus     SubscriptionPaymentStatus  @default(NOT_APPLICABLE)
  paymentMethod     SubscriptionPaymentMethod?
  referenceNumber   String?
  invoiceNumber     String?
  lastPaymentAt     DateTime?
  nextRenewalAt     DateTime?
  assignedById      String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlanCatalog @relation(fields: [planId], references: [id])
  assignedBy     User?                 @relation("SubscriptionAssignedBy", fields: [assignedById], references: [id])
  history        SubscriptionHistory[]
  notifications  SubscriptionNotification[]
  activityLogs   SubscriptionActivityLog[]
  payments       SubscriptionPayment[]
  renewals       SubscriptionRenewal[]
  discounts      SubscriptionDiscount[]
  billingCycle   BillingCycle               @default(MONTHLY)
  currency       String                     @default("USD")
  gracePeriodDays Int                       @default(0)
  trialEndsAt    DateTime?
  paymentGateway String?
  taxRatePercent Decimal?                   @db.Decimal(5, 2)
  discountPercent Decimal?                  @db.Decimal(5, 2)
  lifetimeRevenueUsd Decimal                @default(0) @db.Decimal(12, 2)
  mrrContributionUsd Decimal                @default(0) @db.Decimal(12, 2)
  arrContributionUsd Decimal                @default(0) @db.Decimal(12, 2)

  @@index([status])
  @@index([expiresAt])
  @@index([planId])
  @@map("business_subscriptions")
}

model SubscriptionHistory {
  id                     String                @id @default(uuid())
  businessSubscriptionId String
  businessId             String
  planId                 String?
  status                 BusinessLicenseStatus
  activatedAt            DateTime?
  expiresAt              DateTime?
  action                 SubscriptionActivityAction
  reason                 String?
  metadata               Json?
  performedById          String?
  createdAt              DateTime              @default(now())

  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlanCatalog? @relation(fields: [planId], references: [id])
  performedBy          User?                @relation("SubscriptionHistoryPerformedBy", fields: [performedById], references: [id])

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([createdAt])
  @@map("subscription_history")
}

model SubscriptionNotification {
  id                     String                       @id @default(uuid())
  businessId             String
  businessSubscriptionId String
  channel                SubscriptionNotificationChannel
  type                   SubscriptionNotificationType
  status                 SubscriptionNotificationStatus @default(PENDING)
  scheduledFor           DateTime
  sentAt                 DateTime?
  message                String?
  error                  String?
  metadata               Json?
  createdAt              DateTime                     @default(now())

  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([scheduledFor])
  @@index([status])
  @@map("subscription_notifications")
}

model SubscriptionActivityLog {
  id                     String                   @id @default(uuid())
  businessId             String
  businessSubscriptionId String?
  action                 SubscriptionActivityAction
  performedById          String?
  performedByEmail       String?
  ipAddress              String?
  oldValue               Json?
  newValue               Json?
  notes                  String?
  createdAt              DateTime                 @default(now())

  business             Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription? @relation(fields: [businessSubscriptionId], references: [id], onDelete: SetNull)
  performedBy          User?                 @relation("SubscriptionActivityPerformedBy", fields: [performedById], references: [id])

  @@index([businessId])
  @@index([action])
  @@index([createdAt])
  @@map("subscription_activity_logs")
}

model SubscriptionPayment {
  id                     String                    @id @default(uuid())
  businessId             String
  businessSubscriptionId String
  amount                 Decimal                   @db.Decimal(10, 2)
  currency               String                    @default("USD")
  status                 SubscriptionPaymentStatus @default(PENDING)
  paymentMethod          SubscriptionPaymentMethod?
  referenceNumber        String?
  invoiceNumber          String?
  provider               String?
  providerRef            String?
  paidAt                 DateTime?
  notes                  String?
  metadata               Json?
  recordedById           String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  recordedBy           User?                @relation("SubscriptionPaymentRecordedBy", fields: [recordedById], references: [id])
  transactions         SubscriptionTransaction[]
  renewals             SubscriptionRenewal[]

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([status])
  @@index([createdAt])
  @@map("subscription_payments")
}

model SubscriptionTransaction {
  id          String                      @id @default(uuid())
  businessId  String
  paymentId   String?
  type        SubscriptionTransactionType
  amount      Decimal                     @db.Decimal(10, 2)
  currency    String                      @default("USD")
  provider    String?
  providerRef String?
  status      SubscriptionTransactionStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime                    @default(now())

  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payment  SubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([paymentId])
  @@index([status])
  @@map("subscription_transactions")
}

model SubscriptionRenewal {
  id                     String   @id @default(uuid())
  businessSubscriptionId String
  paymentId              String?
  previousExpiresAt      DateTime?
  newExpiresAt           DateTime
  renewedById            String?
  reason                 String?
  createdAt              DateTime @default(now())

  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  payment              SubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  renewedBy            User?                @relation("SubscriptionRenewalBy", fields: [renewedById], references: [id])

  @@index([businessSubscriptionId])
  @@index([createdAt])
  @@map("subscription_renewals")
}

model SubscriptionCoupon {
  id            String                   @id @default(uuid())
  code          String                   @unique
  name          String?
  discountType  SubscriptionDiscountType
  discountValue Decimal                  @db.Decimal(10, 2)
