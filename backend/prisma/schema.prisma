model BusinessTypeDefinition {
  id          String   @id
  label       String
  icon        String   @default("📋")
  category    String
  industry    String
  description String
  keywords    String[] @default([])
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("business_type_definitions")
}

// ─── BUSINESS (TENANT) ───────────────────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  industry    Industry @default(OTHER)
  phone       String?
  email       String?
  website     String?
  address     String?
  country     String?
  city        String?
  whatsappNumber String?
  timezone    String   @default("UTC")
  logoUrl     String?
  isActive    Boolean  @default(true)
  onboardingStep Int   @default(0)
  onboardingCompletedAt DateTime?
  onboardingData Json?
  employeeRange String?
  customerVolume String?
  mainGoal    String?
  businessType String?
  businessCategory String?
  whatsappStatus WhatsAppStatus @default(NOT_CONNECTED)
  licenseStatus  BusinessLicenseStatus @default(PENDING)
  isLicenseLocked Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members           BusinessMember[]
  customers         Customer[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  conversationActivities ConversationActivity[]
  conversationFeedback ConversationFeedback[]
  appointments      Appointment[]
  appointmentWorkflows AppointmentWorkflow[]
  appointmentReminderConfigs AppointmentReminderConfig[]
  appointmentAutomationSettings AppointmentAutomationSettings?
  appointmentAnalyticsSnapshot AppointmentAnalyticsSnapshot?
  appointmentTimelineEvents AppointmentTimelineEvent[]
  appointmentWorkflowExecutions AppointmentWorkflowExecution[]
  appointmentNotifications AppointmentNotification[]
  appointmentMessageTemplates AppointmentMessageTemplate[]
  services          Service[]
  knowledgeBases    KnowledgeBase[]
  whatsappAccounts  WhatsAppAccount[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  subscription      Subscription?
  businessSubscription BusinessSubscription?
  subscriptionHistory SubscriptionHistory[]
  subscriptionNotifications SubscriptionNotification[]
  subscriptionActivityLogs SubscriptionActivityLog[]
  subscriptionPayments SubscriptionPayment[]
  subscriptionTransactions SubscriptionTransaction[]
  invoices          Invoice[]
  aiConfiguration   AIConfiguration?
  teamInvitations   TeamInvitation[]
  customerSegments  CustomerSegment[]
  campaigns         Campaign[]
  messageTemplates  MessageTemplate[]
  customerImportJobs CustomerImportJob[]
  campaignJourneys  CampaignJourney[]
  campaignOptOuts   CustomerCampaignOptOut[]
  businessProfile   BusinessProfile?
  employees         Employee[]
  employeeGroups    EmployeeGroup[]
  employeeBroadcasts EmployeeBroadcast[]
  employeeTemplates EmployeeTemplate[]
  employeeConversations EmployeeConversation[]
  employeeImportJobs EmployeeImportJob[]
  governanceApprovalRequests GovernanceApprovalRequest[]
  aiTrainingWorkspace      AiTrainingWorkspace?
  aiTrainingVersions       AiTrainingVersion[]
  aiTrainingJobs           AiTrainingJob[]
  aiDeploymentRequests     AiDeploymentRequest[]
  aiSandboxSessions        AiSandboxSession[]
  aiTrainingInsights       AiTrainingInsight[]
  aiTrainerAssignments     AiTrainerBusiness[]
  knowledgeChunks          KnowledgeChunk[]
  aiUsageEvents            AiUsageEvent[]
  aiDailyRollups           AiDailyRollup[]
  aiConversationMetrics    AiConversationMetric[]
  aiCustomerMetrics        AiCustomerMetric[]
  aiBusinessSnapshot       AiBusinessSnapshot?
  aiTrainingSessionLogs    AiTrainingSessionLog[]
  platformFeatureScopes    PlatformFeatureBusinessScope[]
  platformFeatureAuditLogs PlatformFeatureAuditLog[]
  businessFinancialProfile BusinessFinancialProfile?
  financialAuditLogs       FinancialAuditLog[]
  financialAlerts          FinancialAlert[]
  financialCostEvents      FinancialCostEvent[]

  @@index([slug])
  @@index([isActive])
  @@map("businesses")
}

// ─── USERS & TEAM ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  avatarUrl         String?
  phone             String?
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpires DateTime?
  emailOtpHash      String?
  emailOtpExpires   DateTime?
  emailOtpAttempts  Int       @default(0)
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  resetOtpHash      String?
  resetOtpExpires   DateTime?
  resetOtpAttempts  Int       @default(0)
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  isSuperAdmin      Boolean   @default(false)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  totpBackupCodes   String?
  welcomeSeenAt     DateTime?
  pendingBusinessName String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  businessMemberships BusinessMember[]
  refreshTokens       RefreshToken[]
  sentMessages        Message[]          @relation("SentByUser")
  assignedConversations Conversation[]   @relation("AssignedAgent")
  conversationActivities ConversationActivity[] @relation("ConversationActivityActor")
  assignedAppointments Appointment[]     @relation("AssignedStaff")
  appointmentNotes    AppointmentInternalNote[] @relation("AppointmentNoteAuthor")
  createdAppointments Appointment[]           @relation("AppointmentCreator")
  createdCampaigns    Campaign[]              @relation("CampaignCreator")
  createdEmployeeBroadcasts EmployeeBroadcast[] @relation("EmployeeBroadcastCreator")
  employees           Employee[]
  createdImportJobs   CustomerImportJob[]     @relation("ImportJobCreator")
  createdEmployeeImportJobs EmployeeImportJob[] @relation("EmployeeImportJobCreator")
  ownedEmployeeGroups EmployeeGroup[]         @relation("EmployeeGroupOwner")
  auditLogs           AuditLog[]
  notifications       Notification[]
  assignedSubscriptions BusinessSubscription[] @relation("SubscriptionAssignedBy")
  subscriptionHistoryEntries SubscriptionHistory[] @relation("SubscriptionHistoryPerformedBy")
  subscriptionActivityEntries SubscriptionActivityLog[] @relation("SubscriptionActivityPerformedBy")
  recordedSubscriptionPayments SubscriptionPayment[] @relation("SubscriptionPaymentRecordedBy")
  subscriptionRenewals SubscriptionRenewal[] @relation("SubscriptionRenewalBy")
  appliedSubscriptionDiscounts SubscriptionDiscount[] @relation("SubscriptionDiscountAppliedBy")
  governanceRequestsSubmitted GovernanceApprovalRequest[] @relation("GovernanceRequester")
  governanceRequestsApproved GovernanceApprovalRequest[] @relation("GovernanceApprover")
  governanceRequestsRejected GovernanceApprovalRequest[] @relation("GovernanceRejecter")
  aiVersionsTrained            AiTrainingVersion[]         @relation("AiVersionTrainedByUser")
  aiTrainingJobsCreated        AiTrainingJob[]             @relation("AiJobCreatedByUser")
  aiDeploymentRequests         AiDeploymentRequest[]       @relation("AiDeploymentRequester")
  aiDeploymentApprovals        AiDeploymentRequest[]       @relation("AiDeploymentApprover")
  aiDeploymentRejections       AiDeploymentRequest[]       @relation("AiDeploymentRejecter")
  aiSandboxSessions            AiSandboxSession[]          @relation("AiSandboxUser")
  aiTrainingAuditLogs          AiTrainingAuditLog[]        @relation("AiTrainingAuditUser")
  aiTrainingVerifications      AiTrainingVerificationRequest[] @relation("AiTrainingVerificationUser")
  aiTrainingSessionsOperated   AiTrainingSessionLog[]      @relation("AiTrainingSessionOperator")
  platformFeaturesCreated      PlatformFeature[]           @relation("PlatformFeatureCreatedBy")
  platformFeaturesModified     PlatformFeature[]           @relation("PlatformFeatureModifiedBy")
  platformFeatureVerifications PlatformFeatureVerificationRequest[] @relation("PlatformFeatureVerificationUser")
  platformFeatureAuditLogs     PlatformFeatureAuditLog[]   @relation("PlatformFeatureAuditUser")
  financialAuditLogs           FinancialAuditLog[]         @relation("FinancialAuditOperator")

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  role       UserRole @default(AGENT)
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([role])
  @@map("business_members")
}

model TeamInvitation {
  id         String   @id @default(uuid())
  businessId String
  email      String
  role       UserRole @default(AGENT)
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── CUSTOMERS (CRM) ─────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid())
  businessId    String
  name          String
  phone         String
  email         String?
  whatsappId    String?
  whatsappNumber String?
  companyName   String?
  address       String?
  city          String?
  country       String?
  notes         String?
  source        String?
  customerType  CustomerType @default(REGULAR)
  leadStatus    LeadStatus   @default(NEW)
  leadScore     Int          @default(0)
  customerValue Decimal?     @db.Decimal(12, 2)
  aiSummary     Json?
  isActive      Boolean      @default(true)
  lastContactAt DateTime?
  /** Latest inbound WhatsApp message time (Meta customer care window anchor). */
  lastCustomerMessageAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business      Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tags          CustomerTagAssignment[]
  conversations Conversation[]
  appointments  Appointment[]
  appointmentNotifications AppointmentNotification[]
  customerNotes CustomerNote[]
  segmentMembers CustomerSegmentMember[]
  campaignRecipients CampaignRecipient[]
  targetedCampaigns Campaign[] @relation("CampaignTargetCustomer")
  journeyEnrollments CampaignJourneyEnrollment[]
  campaignOptOut     CustomerCampaignOptOut?

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, email])
  @@index([businessId, lastContactAt])
  @@index([whatsappId])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  color      String   @default("#651147")
  createdAt  DateTime @default(now())

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers CustomerTagAssignment[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  assignedAt DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  content    String
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

// ─── CONVERSATIONS & MESSAGES ────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(uuid())
  businessId      String
  customerId      String
  whatsappAccountId String?
  status          ConversationStatus @default(AI_HANDLING)
  assignedToId    String?
  assignedTeam    ConversationTeam?
  isAiEnabled     Boolean            @default(true)
  isTyping        Boolean            @default(false)
  unreadCount     Int                @default(0)
  lastMessageAt   DateTime?
  /** Latest inbound WhatsApp message in this thread (session window anchor). */
  lastCustomerMessageAt DateTime?
  resolvedAt      DateTime?
  aiStartTime     DateTime?
  humanStartTime  DateTime?
  transferTime    DateTime?
  aiConfidenceScore Float?
  resolutionMethod ResolutionMethod?
  awaitingFeedback Boolean           @default(false)
  feedbackPromptedAt DateTime?
  memorySummary    String?
  memorySummaryAt  DateTime?
  memoryMessageCount Int             @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id])
  assignedTo      User?            @relation("AssignedAgent", fields: [assignedToId], references: [id])
  messages        Message[]
  activities      ConversationActivity[]
  feedback        ConversationFeedback[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([businessId, assignedToId])
  @@index([businessId, customerId, status])
  @@index([businessId, assignedTeam])
  @@index([customerId])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  mediaUrl       String?
  whatsappMsgId  String?          @unique
  status         MessageStatus    @default(PENDING)
  isAiGenerated  Boolean          @default(false)
  sentByUserId   String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("SentByUser", fields: [sentByUserId], references: [id])

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([whatsappMsgId])
  @@index([direction])
  @@map("messages")
}

model ConversationActivity {
  id             String                   @id @default(uuid())
  businessId     String
  conversationId String
  type           ConversationActivityType
  title          String
  description    String?
  actorUserId    String?
  metadata       Json?
  createdAt      DateTime                 @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation("ConversationActivityActor", fields: [actorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@index([businessId, createdAt])
  @@map("conversation_activities")
}

model ConversationFeedback {
