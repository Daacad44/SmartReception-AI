}

// ─── APPOINTMENT AUTOMATION PLATFORM ─────────────────────────────────────────

model AppointmentWorkflow {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  templateKey String?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stages       AppointmentWorkflowStage[]
  transitions  AppointmentWorkflowTransition[]
  rules        AppointmentWorkflowRule[]
  appointments Appointment[]
  executions   AppointmentWorkflowExecution[]
  reminderConfigs AppointmentReminderConfig[]

  @@index([businessId])
  @@index([businessId, isDefault])
  @@map("appointment_workflows")
}

model AppointmentWorkflowStage {
  id               String   @id @default(uuid())
  workflowId       String
  businessId       String
  key              String
  label            String
  color            String   @default("#651147")
  sortOrder        Int      @default(0)
  isEnabled        Boolean  @default(true)
  isTerminal       Boolean  @default(false)
  requiresApproval Boolean  @default(false)
  positionX        Float    @default(0)
  positionY        Float    @default(0)
  defaultActions   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workflow         AppointmentWorkflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  transitionsFrom  AppointmentWorkflowTransition[] @relation("TransitionFrom")
  transitionsTo    AppointmentWorkflowTransition[] @relation("TransitionTo")

  @@unique([workflowId, key])
  @@index([businessId])
  @@index([workflowId, sortOrder])
  @@map("appointment_workflow_stages")
}

model AppointmentWorkflowTransition {
  id           String   @id @default(uuid())
  workflowId   String
  businessId   String
  fromStageId  String
  toStageId    String
  triggerEvent AppointmentWorkflowEventType
  conditions   Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflow  AppointmentWorkflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStage AppointmentWorkflowStage @relation("TransitionFrom", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStage   AppointmentWorkflowStage @relation("TransitionTo", fields: [toStageId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([businessId])
  @@index([triggerEvent])
  @@map("appointment_workflow_transitions")
}

model AppointmentWorkflowRule {
  id           String                       @id @default(uuid())
  workflowId   String
  businessId   String
  name         String
  triggerEvent AppointmentWorkflowEventType
  conditions   Json                         @default("[]")
  actions      Json                         @default("[]")
  priority     Int                          @default(0)
  isActive     Boolean                      @default(true)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  workflow AppointmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([businessId])
  @@index([triggerEvent])
  @@map("appointment_workflow_rules")
}

model AppointmentWorkflowTemplate {
  id          String   @id @default(uuid())
  key         String   @unique
  industry    String
  name        String
  description String
  definition  Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([industry])
  @@map("appointment_workflow_templates")
}

model AppointmentTimelineEvent {
  id            String                       @id @default(uuid())
