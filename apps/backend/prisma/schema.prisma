}

// ─── AI CONFIGURATION ────────────────────────────────────────────────────────

model AIConfiguration {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  systemPrompt          String?
  temperature           Float    @default(0.7)
  maxTokens             Int      @default(500)
  enableAutoReply       Boolean  @default(true)
  enableBooking         Boolean  @default(true)
  enableLeadQualification Boolean @default(true)
  languages             String[] @default(["en"])
  greetingMessage       String?
  fallbackMessage       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("ai_configurations")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  businessId String
  userId     String?
  type       NotificationType
  title      String
  message    String
  data       Json?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([businessId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  businessId String?
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── EMPLOYEE COMMUNICATION CENTER ───────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum EmployeeBroadcastType {
  ANNOUNCEMENT
  NOTIFICATION
  EMERGENCY
  MEETING
  HOLIDAY
  POLICY
  TRAINING
  MOTIVATION
  PAYROLL
  SHIFT
  CUSTOM
}

enum EmployeeBroadcastSchedule {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  RECURRING
}

enum EmployeeBroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
  ARCHIVED
}

enum EmployeeDeliveryStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Employee {
  id              String          @id @default(uuid())
  businessId      String
  employeeCode    String?
  fullName        String
  jobTitle        String?
  department      String?
  role            String?
  phone           String
  whatsappNumber  String?
  email           String?
  status          EmployeeStatus  @default(ACTIVE)
  profilePhotoUrl String?
  branch          String?
  managerId       String?
  hireDate        DateTime?
  employmentType  EmploymentType  @default(FULL_TIME)
  permissions     Json?
  tags            String[]        @default([])
  notes           String?
  emergencyContact String?
  language        String          @default("so")
  timezone        String?
  lastActiveAt    DateTime?
  userId          String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  business            Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  manager             Employee?                   @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports       Employee[]                  @relation("EmployeeManager")
  user                User?                       @relation(fields: [userId], references: [id])
  groupMembers        EmployeeGroupMember[]
  broadcastRecipients EmployeeBroadcastRecipient[]
  conversations       EmployeeConversation[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, department])
  @@index([businessId, branch])
  @@index([businessId, fullName])
  @@index([businessId, email])
  @@map("employees")
}

model EmployeeGroup {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  description String?
  color       String    @default("#651147")
  department  String?
  status      String    @default("ACTIVE")
  ownerId     String?
  notes       String?
  isSystem    Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business   Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  owner      User?                 @relation("EmployeeGroupOwner", fields: [ownerId], references: [id])
  members    EmployeeGroupMember[]
  broadcasts EmployeeBroadcast[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([businessId, status])
  @@map("employee_groups")
}

model EmployeeGroupMember {
  employeeId String
  groupId    String
  addedAt    DateTime @default(now())

  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  group    EmployeeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([employeeId, groupId])
  @@index([groupId])
  @@map("employee_group_members")
}

model EmployeeTemplate {
  id         String   @id @default(uuid())
  businessId String
  name       String
  content    String
  category   String   @default("GENERAL")
  variables  String[] @default([])
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  broadcasts EmployeeBroadcast[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([businessId, category])
  @@map("employee_templates")
}

model EmployeeBroadcast {
  id             String                    @id @default(uuid())
  businessId     String
  name           String
  message        String
  type           EmployeeBroadcastType     @default(ANNOUNCEMENT)
  schedule       EmployeeBroadcastSchedule @default(ONE_TIME)
  status         EmployeeBroadcastStatus   @default(DRAFT)
  messageType    CampaignMessageType       @default(TEXT)
  groupId        String?
  groupIds       String[]                  @default([])
  department     String?
  branch         String?
  roles          String[]                  @default([])
  tags           String[]                  @default([])
  audienceFilter Json?
  employeeIds    String[]                  @default([])
  sendToAll      Boolean                   @default(false)
  templateId     String?
  mediaUrl       String?
  mediaFilename  String?
  timezone       String?
  cronExpression String?
  scheduleConfig Json?
  repeatCount    Int?
  repeatUntil    DateTime?
  runsCompleted  Int                       @default(0)
  scheduledAt    DateTime?
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  isEmergency    Boolean                   @default(false)
  createdById    String?
  sentCount      Int                       @default(0)
  deliveredCount Int                       @default(0)
  failedCount    Int                       @default(0)
  readCount      Int                       @default(0)
  responseCount  Int                       @default(0)
  archivedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  business   Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  group      EmployeeGroup?               @relation(fields: [groupId], references: [id])
  template   EmployeeTemplate?            @relation(fields: [templateId], references: [id])
  createdBy  User?                        @relation("EmployeeBroadcastCreator", fields: [createdById], references: [id])
  recipients EmployeeBroadcastRecipient[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([scheduledAt])
  @@index([nextRunAt])
  @@map("employee_broadcasts")
}

model EmployeeBroadcastRecipient {
  id            String                 @id @default(uuid())
  broadcastId   String
  employeeId    String
  phone         String
  status        EmployeeDeliveryStatus @default(PENDING)
  isSent        Boolean                @default(false)
  runVersion    Int                    @default(0)
  whatsappMsgId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  respondedAt   DateTime?
  failedReason  String?
  retryCount    Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  broadcast EmployeeBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  employee  Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, employeeId])
  @@index([broadcastId])
  @@index([employeeId])
  @@index([status])
  @@map("employee_broadcast_recipients")
}

model EmployeeConversation {
  id                String   @id @default(uuid())
  businessId        String
  employeeId        String
  whatsappAccountId String?
  status            String   @default("OPEN")
  unreadCount       Int      @default(0)
  lastMessageAt     DateTime?
  labels            String[] @default([])
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business  Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee  Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  messages  EmployeeConversationMessage[]

  @@unique([businessId, employeeId])
  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@map("employee_conversations")
}

model EmployeeConversationMessage {
  id             String   @id @default(uuid())
  conversationId String
  direction      String
  content        String
  type           String   @default("TEXT")
  mediaUrl       String?
  mediaFilename  String?
  whatsappMsgId  String?
  status         String   @default("PENDING")
  isAiGenerated  Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation EmployeeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([whatsappMsgId])
  @@map("employee_conversation_messages")
}

model EmployeeImportJob {
  id             String          @id @default(uuid())
  businessId     String
  fileName       String
  fileType       String
  status         ImportJobStatus @default(PENDING)
  totalRows      Int             @default(0)
  importedCount  Int             @default(0)
  duplicateCount Int             @default(0)
  invalidCount   Int             @default(0)
  report         Json?
  createdById    String?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("EmployeeImportJobCreator", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([businessId, createdAt])
  @@map("employee_import_jobs")
}

// ─── BILLING ─────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  businessId           String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

model Invoice {
  id              String        @id @default(uuid())
  businessId      String
  invoiceNumber   String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          InvoiceStatus @default(DRAFT)
  stripeInvoiceId String?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

// ─── ENTERPRISE SUBSCRIPTION & LICENSE ───────────────────────────────────────

model SubscriptionPlanCatalog {
  id                   String           @id @default(uuid())
  code                 SubscriptionPlan @unique
  name                 String
  description          String?
  features             Json?
  featureFlags         Json?
  monthlyPrice         Decimal          @default(0) @db.Decimal(10, 2)
  yearlyPrice          Decimal          @default(0) @db.Decimal(10, 2)
  maxUsers             Int              @default(1)
  maxConversations     Int              @default(100)
  maxWhatsappNumbers   Int              @default(1)
  maxAiAgents          Int              @default(1)
  storageLimitMb       Int              @default(512)
  knowledgeBaseLimit   Int              @default(1)
  teamLimit            Int              @default(1)
  campaignLimit        Int              @default(0)
  appointmentLimit     Int              @default(50)
  sortOrder            Int              @default(0)
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  businessSubscriptions BusinessSubscription[]
  history               SubscriptionHistory[]

  @@map("subscription_plans")
}

model BusinessSubscription {
  id                String                     @id @default(uuid())
  businessId        String                     @unique
  planId            String
  previousPlanId    String?
  status            BusinessLicenseStatus      @default(PENDING)
  durationPreset    SubscriptionDurationPreset?
  durationDays      Int?
  activatedAt       DateTime?
  expiresAt         DateTime?
  pausedAt          DateTime?
  cancelledAt       DateTime?
  lockedAt          DateTime?
  isPaused          Boolean                    @default(false)
  isTrial           Boolean                    @default(false)
  internalNotes     String?
  paymentStatus     SubscriptionPaymentStatus  @default(NOT_APPLICABLE)
  paymentMethod     SubscriptionPaymentMethod?
  referenceNumber   String?
  invoiceNumber     String?
  lastPaymentAt     DateTime?
  nextRenewalAt     DateTime?
  assignedById      String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlanCatalog @relation(fields: [planId], references: [id])
  assignedBy     User?                 @relation("SubscriptionAssignedBy", fields: [assignedById], references: [id])
  history        SubscriptionHistory[]
  notifications  SubscriptionNotification[]
  activityLogs   SubscriptionActivityLog[]
  payments       SubscriptionPayment[]
  renewals       SubscriptionRenewal[]
  discounts      SubscriptionDiscount[]

  @@index([status])
  @@index([expiresAt])
  @@index([planId])
  @@map("business_subscriptions")
}

model SubscriptionHistory {
  id                     String                @id @default(uuid())
  businessSubscriptionId String
  businessId             String
  planId                 String?
  status                 BusinessLicenseStatus
  activatedAt            DateTime?
  expiresAt              DateTime?
  action                 SubscriptionActivityAction
  reason                 String?
  metadata               Json?
  performedById          String?
  createdAt              DateTime              @default(now())

  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlanCatalog? @relation(fields: [planId], references: [id])
  performedBy          User?                @relation("SubscriptionHistoryPerformedBy", fields: [performedById], references: [id])

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([createdAt])
  @@map("subscription_history")
}

model SubscriptionNotification {
  id                     String                       @id @default(uuid())
  businessId             String
  businessSubscriptionId String
  channel                SubscriptionNotificationChannel
  type                   SubscriptionNotificationType
  status                 SubscriptionNotificationStatus @default(PENDING)
  scheduledFor           DateTime
  sentAt                 DateTime?
  message                String?
  error                  String?
  metadata               Json?
  createdAt              DateTime                     @default(now())

  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([scheduledFor])
  @@index([status])
  @@map("subscription_notifications")
}

model SubscriptionActivityLog {
  id                     String                   @id @default(uuid())
  businessId             String
  businessSubscriptionId String?
  action                 SubscriptionActivityAction
  performedById          String?
  performedByEmail       String?
  ipAddress              String?
  oldValue               Json?
  newValue               Json?
  notes                  String?
  createdAt              DateTime                 @default(now())

  business             Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription? @relation(fields: [businessSubscriptionId], references: [id], onDelete: SetNull)
  performedBy          User?                 @relation("SubscriptionActivityPerformedBy", fields: [performedById], references: [id])

  @@index([businessId])
  @@index([action])
  @@index([createdAt])
  @@map("subscription_activity_logs")
}

model SubscriptionPayment {
  id                     String                    @id @default(uuid())
  businessId             String
  businessSubscriptionId String
  amount                 Decimal                   @db.Decimal(10, 2)
  currency               String                    @default("USD")
  status                 SubscriptionPaymentStatus @default(PENDING)
  paymentMethod          SubscriptionPaymentMethod?
  referenceNumber        String?
  invoiceNumber          String?
  provider               String?
  providerRef            String?
  paidAt                 DateTime?
  notes                  String?
  metadata               Json?
  recordedById           String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  recordedBy           User?                @relation("SubscriptionPaymentRecordedBy", fields: [recordedById], references: [id])
  transactions         SubscriptionTransaction[]
  renewals             SubscriptionRenewal[]

  @@index([businessId])
  @@index([businessSubscriptionId])
  @@index([status])
  @@index([createdAt])
  @@map("subscription_payments")
}

model SubscriptionTransaction {
  id          String                      @id @default(uuid())
  businessId  String
  paymentId   String?
  type        SubscriptionTransactionType
  amount      Decimal                     @db.Decimal(10, 2)
  currency    String                      @default("USD")
  provider    String?
  providerRef String?
  status      SubscriptionTransactionStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime                    @default(now())

  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payment  SubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([paymentId])
  @@index([status])
  @@map("subscription_transactions")
}

model SubscriptionRenewal {
  id                     String   @id @default(uuid())
  businessSubscriptionId String
  paymentId              String?
  previousExpiresAt      DateTime?
  newExpiresAt           DateTime
  renewedById            String?
  reason                 String?
  createdAt              DateTime @default(now())

  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  payment              SubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  renewedBy            User?                @relation("SubscriptionRenewalBy", fields: [renewedById], references: [id])

  @@index([businessSubscriptionId])
  @@index([createdAt])
  @@map("subscription_renewals")
}

model SubscriptionCoupon {
  id            String                   @id @default(uuid())
  code          String                   @unique
  name          String?
  discountType  SubscriptionDiscountType
  discountValue Decimal                  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int                      @default(0)
  expiresAt     DateTime?
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  discounts SubscriptionDiscount[]

  @@map("subscription_coupons")
}

model SubscriptionDiscount {
  id                     String                   @id @default(uuid())
  businessSubscriptionId String
  couponId               String?
  discountType           SubscriptionDiscountType
  discountValue          Decimal                  @db.Decimal(10, 2)
  appliedAt              DateTime                 @default(now())
  appliedById            String?

  businessSubscription BusinessSubscription @relation(fields: [businessSubscriptionId], references: [id], onDelete: Cascade)
  coupon               SubscriptionCoupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  appliedBy            User?                  @relation("SubscriptionDiscountAppliedBy", fields: [appliedById], references: [id])

  @@index([businessSubscriptionId])
  @@map("subscription_discounts")
}

// ─── ENTERPRISE GOVERNANCE ───────────────────────────────────────────────────

model GovernanceApprovalRequest {
  id                      String                   @id @default(uuid())
  businessId              String
  requesterUserId         String
  actionType              GovernanceActionType
  status                  GovernanceApprovalStatus @default(PENDING)
  payload                 Json
  previousData            Json?
  stagingStorageKey       String?
  stagingMimeType         String?
  stagingFilename         String?
  ipAddress               String?
  userAgent               String?
  deviceLabel             String?
  approvedByUserId        String?
  approvedAt              DateTime?
  rejectedByUserId        String?
  rejectedAt              DateTime?
  rejectionReason         String?
  activationCodeHash      String?
  activationCodeExpiresAt DateTime?
  activationCodeUsedAt    DateTime?
  executedAt              DateTime?
  executionResult         Json?
  auditEntityId           String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requester User     @relation("GovernanceRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approver  User?    @relation("GovernanceApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejecter  User?    @relation("GovernanceRejecter", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

