model BusinessTypeDefinition {
  id          String   @id
  label       String
  icon        String   @default("📋")
  category    String
  industry    String
  description String
  keywords    String[] @default([])
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("business_type_definitions")
}

// ─── BUSINESS (TENANT) ───────────────────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  industry    Industry @default(OTHER)
  phone       String?
  email       String?
  website     String?
  address     String?
  country     String?
  city        String?
  whatsappNumber String?
  timezone    String   @default("UTC")
  logoUrl     String?
  isActive    Boolean  @default(true)
  onboardingStep Int   @default(0)
  onboardingCompletedAt DateTime?
  onboardingData Json?
  employeeRange String?
  customerVolume String?
  mainGoal    String?
  businessType String?
  businessCategory String?
  whatsappStatus WhatsAppStatus @default(NOT_CONNECTED)
  licenseStatus  BusinessLicenseStatus @default(PENDING)
  isLicenseLocked Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members           BusinessMember[]
  customers         Customer[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  conversationActivities ConversationActivity[]
  conversationFeedback ConversationFeedback[]
  appointments      Appointment[]
  appointmentNotifications AppointmentNotification[]
  services          Service[]
  knowledgeBases    KnowledgeBase[]
  whatsappAccounts  WhatsAppAccount[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  subscription      Subscription?
  businessSubscription BusinessSubscription?
  subscriptionHistory SubscriptionHistory[]
  subscriptionNotifications SubscriptionNotification[]
  subscriptionActivityLogs SubscriptionActivityLog[]
  subscriptionPayments SubscriptionPayment[]
  subscriptionTransactions SubscriptionTransaction[]
  invoices          Invoice[]
  aiConfiguration   AIConfiguration?
  teamInvitations   TeamInvitation[]
  customerSegments  CustomerSegment[]
  campaigns         Campaign[]
  messageTemplates  MessageTemplate[]
  customerImportJobs CustomerImportJob[]
  campaignJourneys  CampaignJourney[]
  campaignOptOuts   CustomerCampaignOptOut[]
  businessProfile   BusinessProfile?
  employees         Employee[]
  employeeGroups    EmployeeGroup[]
  employeeBroadcasts EmployeeBroadcast[]
  employeeTemplates EmployeeTemplate[]
  employeeConversations EmployeeConversation[]
  employeeImportJobs EmployeeImportJob[]
  governanceApprovalRequests GovernanceApprovalRequest[]
  aiTrainingWorkspace      AiTrainingWorkspace?
  aiTrainingVersions       AiTrainingVersion[]
  aiTrainingJobs           AiTrainingJob[]
  aiDeploymentRequests     AiDeploymentRequest[]
  aiSandboxSessions        AiSandboxSession[]
  aiTrainingInsights       AiTrainingInsight[]
  aiTrainerAssignments     AiTrainerBusiness[]
  knowledgeChunks          KnowledgeChunk[]
  aiUsageEvents            AiUsageEvent[]
  aiDailyRollups           AiDailyRollup[]
  aiConversationMetrics    AiConversationMetric[]
  aiCustomerMetrics        AiCustomerMetric[]

  @@index([slug])
  @@index([isActive])
  @@map("businesses")
}

// ─── USERS & TEAM ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  avatarUrl         String?
  phone             String?
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpires DateTime?
  emailOtpHash      String?
  emailOtpExpires   DateTime?
  emailOtpAttempts  Int       @default(0)
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  resetOtpHash      String?
  resetOtpExpires   DateTime?
  resetOtpAttempts  Int       @default(0)
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  isSuperAdmin      Boolean   @default(false)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  totpBackupCodes   String?
  welcomeSeenAt     DateTime?
  pendingBusinessName String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  businessMemberships BusinessMember[]
  refreshTokens       RefreshToken[]
  sentMessages        Message[]          @relation("SentByUser")
  assignedConversations Conversation[]   @relation("AssignedAgent")
  conversationActivities ConversationActivity[] @relation("ConversationActivityActor")
  assignedAppointments Appointment[]     @relation("AssignedStaff")
  appointmentNotes    AppointmentInternalNote[] @relation("AppointmentNoteAuthor")
  createdAppointments Appointment[]           @relation("AppointmentCreator")
  createdCampaigns    Campaign[]              @relation("CampaignCreator")
  createdEmployeeBroadcasts EmployeeBroadcast[] @relation("EmployeeBroadcastCreator")
  employees           Employee[]
  createdImportJobs   CustomerImportJob[]     @relation("ImportJobCreator")
  createdEmployeeImportJobs EmployeeImportJob[] @relation("EmployeeImportJobCreator")
  ownedEmployeeGroups EmployeeGroup[]         @relation("EmployeeGroupOwner")
  auditLogs           AuditLog[]
  notifications       Notification[]
  assignedSubscriptions BusinessSubscription[] @relation("SubscriptionAssignedBy")
  subscriptionHistoryEntries SubscriptionHistory[] @relation("SubscriptionHistoryPerformedBy")
  subscriptionActivityEntries SubscriptionActivityLog[] @relation("SubscriptionActivityPerformedBy")
  recordedSubscriptionPayments SubscriptionPayment[] @relation("SubscriptionPaymentRecordedBy")
  subscriptionRenewals SubscriptionRenewal[] @relation("SubscriptionRenewalBy")
  appliedSubscriptionDiscounts SubscriptionDiscount[] @relation("SubscriptionDiscountAppliedBy")
  governanceRequestsSubmitted GovernanceApprovalRequest[] @relation("GovernanceRequester")
  governanceRequestsApproved GovernanceApprovalRequest[] @relation("GovernanceApprover")
  governanceRequestsRejected GovernanceApprovalRequest[] @relation("GovernanceRejecter")
  aiVersionsTrained            AiTrainingVersion[]         @relation("AiVersionTrainedByUser")
  aiTrainingJobsCreated        AiTrainingJob[]             @relation("AiJobCreatedByUser")
  aiDeploymentRequests         AiDeploymentRequest[]       @relation("AiDeploymentRequester")
  aiDeploymentApprovals        AiDeploymentRequest[]       @relation("AiDeploymentApprover")
  aiDeploymentRejections       AiDeploymentRequest[]       @relation("AiDeploymentRejecter")
  aiSandboxSessions            AiSandboxSession[]          @relation("AiSandboxUser")
  aiTrainingAuditLogs          AiTrainingAuditLog[]        @relation("AiTrainingAuditUser")

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  role       UserRole @default(AGENT)
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([role])
  @@map("business_members")
}

model TeamInvitation {
  id         String   @id @default(uuid())
  businessId String
  email      String
  role       UserRole @default(AGENT)
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── CUSTOMERS (CRM) ─────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid())
  businessId    String
  name          String
  phone         String
  email         String?
  whatsappId    String?
  whatsappNumber String?
  companyName   String?
  address       String?
  city          String?
  country       String?
  notes         String?
  source        String?
  customerType  CustomerType @default(REGULAR)
  leadStatus    LeadStatus   @default(NEW)
  leadScore     Int          @default(0)
  customerValue Decimal?     @db.Decimal(12, 2)
  aiSummary     Json?
  isActive      Boolean      @default(true)
  lastContactAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business      Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tags          CustomerTagAssignment[]
  conversations Conversation[]
  appointments  Appointment[]
  appointmentNotifications AppointmentNotification[]
  customerNotes CustomerNote[]
  segmentMembers CustomerSegmentMember[]
  campaignRecipients CampaignRecipient[]
  targetedCampaigns Campaign[] @relation("CampaignTargetCustomer")
  journeyEnrollments CampaignJourneyEnrollment[]
  campaignOptOut     CustomerCampaignOptOut?

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, email])
  @@index([businessId, lastContactAt])
  @@index([whatsappId])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  color      String   @default("#651147")
  createdAt  DateTime @default(now())

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers CustomerTagAssignment[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  assignedAt DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  content    String
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

// ─── CONVERSATIONS & MESSAGES ────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(uuid())
  businessId      String
  customerId      String
  whatsappAccountId String?
  status          ConversationStatus @default(AI_HANDLING)
  assignedToId    String?
  assignedTeam    ConversationTeam?
  isAiEnabled     Boolean            @default(true)
  isTyping        Boolean            @default(false)
  unreadCount     Int                @default(0)
  lastMessageAt   DateTime?
  resolvedAt      DateTime?
  aiStartTime     DateTime?
  humanStartTime  DateTime?
  transferTime    DateTime?
  aiConfidenceScore Float?
  resolutionMethod ResolutionMethod?
  awaitingFeedback Boolean           @default(false)
  feedbackPromptedAt DateTime?
  memorySummary    String?
  memorySummaryAt  DateTime?
  memoryMessageCount Int             @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id])
  assignedTo      User?            @relation("AssignedAgent", fields: [assignedToId], references: [id])
  messages        Message[]
  activities      ConversationActivity[]
  feedback        ConversationFeedback[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([businessId, assignedToId])
  @@index([businessId, customerId, status])
  @@index([businessId, assignedTeam])
  @@index([customerId])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  mediaUrl       String?
  whatsappMsgId  String?          @unique
  status         MessageStatus    @default(PENDING)
  isAiGenerated  Boolean          @default(false)
  sentByUserId   String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("SentByUser", fields: [sentByUserId], references: [id])

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([whatsappMsgId])
  @@index([direction])
  @@map("messages")
}

model ConversationActivity {
  id             String                   @id @default(uuid())
  businessId     String
  conversationId String
  type           ConversationActivityType
  title          String
  description    String?
  actorUserId    String?
  metadata       Json?
  createdAt      DateTime                 @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation("ConversationActivityActor", fields: [actorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@index([businessId, createdAt])
  @@map("conversation_activities")
}

model ConversationFeedback {
  id                String            @id @default(uuid())
  businessId        String
  conversationId    String
  rating            Int?
  helpful           Boolean?
  resolutionMethod  ResolutionMethod?
  resolutionTimeMs  Int?
  employeeName      String?
  aiConfidenceScore Float?
  comment           String?
  createdAt         DateTime          @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([businessId, createdAt])
  @@map("conversation_feedback")
}

// ─── APPOINTMENTS & SERVICES ─────────────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  duration    Int      @default(30)
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, isActive])
  @@map("services")
}

model Appointment {
  id                     String              @id @default(uuid())
  businessId             String
  customerId             String
  serviceId              String?
  assignedToId           String?
  createdById            String?
  title                  String
  description            String?
  serviceRequested       String?
  serviceCategory        String?
  companyName            String?
  additionalNotes        String?
  requirementsCollected  Json?
  aiConversationSummary  Json?
  budget                 Decimal?            @db.Decimal(12, 2)
  leadSource             String?             @default("WHATSAPP")
  meetingLink            String?
  priority               AppointmentPriority @default(MEDIUM)
  startTime              DateTime
  endTime                DateTime
  status                 AppointmentStatus   @default(SCHEDULED)
  rejectionReason        String?
  notes                  String?
  reminderSent           Boolean             @default(false)
  reminder24hSent        Boolean             @default(false)
  reminder1hSent         Boolean             @default(false)
  reminder15mSent        Boolean             @default(false)
  reminder30mSent        Boolean             @default(false)
  reminder20mSent        Boolean             @default(false)
  reminder10mSent        Boolean             @default(false)
  followUp24hSent        Boolean             @default(false)
  missedNotificationSent Boolean             @default(false)
  confirmationSentAt     DateTime?
  missedAt               DateTime?
  canRebookAfter         DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service       Service?                  @relation(fields: [serviceId], references: [id])
  assignedTo    User?                     @relation("AssignedStaff", fields: [assignedToId], references: [id])
  createdBy     User?                     @relation("AppointmentCreator", fields: [createdById], references: [id])
  internalNotes AppointmentInternalNote[]
  notifications AppointmentNotification[]

  @@index([businessId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([priority])
  @@map("appointments")
}

model AppointmentInternalNote {
  id            String   @id @default(uuid())
  appointmentId String
  content       String
  createdById   String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("AppointmentNoteAuthor", fields: [createdById], references: [id])

  @@index([appointmentId])
  @@map("appointment_internal_notes")
}

model AppointmentNotification {
  id               String                       @id @default(uuid())
  appointmentId    String
  businessId       String
  customerId       String
  channel          AppointmentNotificationChannel
  notificationType AppointmentNotificationType
  scheduledAt      DateTime?
  sentAt           DateTime?
  status           AppointmentNotificationStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime                     @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, notificationType, channel])
  @@index([appointmentId])
  @@index([businessId, status])
  @@index([scheduledAt, status])
  @@map("appointment_notifications")
}

// ─── CUSTOMER SEGMENTS & CAMPAIGNS ───────────────────────────────────────────

model CustomerSegment {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#D97706")
  customerType CustomerType?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  members   CustomerSegmentMember[]
  campaigns Campaign[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_segments")
}

model CustomerSegmentMember {
  segmentId  String
  customerId String
  addedAt    DateTime @default(now())

  segment  CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([segmentId, customerId])
  @@index([customerId])
  @@map("customer_segment_members")
}

model Campaign {
  id               String              @id @default(uuid())
  businessId       String
  name             String
  message          String
  type             CampaignType        @default(MARKETING)
  schedule         CampaignSchedule    @default(ONE_TIME)
  status           CampaignStatus      @default(DRAFT)
  messageType      CampaignMessageType @default(TEXT)
  segmentId        String?
  templateId       String?
  customerTypes    CustomerType[]
  sendToAll        Boolean             @default(false)
  targetCustomerId String?
  isSent           Boolean             @default(false)
  runVersion       Int                 @default(0)
  scheduledAt      DateTime?
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  timezone         String?
  cronExpression   String?
  scheduleConfig   Json?
  repeatCount      Int?
  repeatUntil      DateTime?
  runsCompleted    Int                 @default(0)
  mediaUrl         String?
  mediaFilename    String?
  category         String?
  journeyId        String?
  createdById      String?
  sentCount        Int                 @default(0)
  deliveredCount   Int                 @default(0)
  failedCount      Int                 @default(0)
  readCount        Int                 @default(0)
  responseCount    Int                 @default(0)
  linkClickCount   Int                 @default(0)
  optOutCount      Int                 @default(0)
  blockedCount     Int                 @default(0)
  archivedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  segment        CustomerSegment?    @relation(fields: [segmentId], references: [id])
  template       MessageTemplate?    @relation(fields: [templateId], references: [id])
  targetCustomer Customer?           @relation("CampaignTargetCustomer", fields: [targetCustomerId], references: [id])
  journey        CampaignJourney?    @relation(fields: [journeyId], references: [id])
  createdBy      User?               @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients     CampaignRecipient[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([scheduledAt])
  @@index([nextRunAt])
  @@index([templateId])
  @@index([targetCustomerId])
  @@index([journeyId])
  @@map("campaigns")
}

model CampaignRecipient {
  id            String                  @id @default(uuid())
  campaignId    String
  customerId    String
  phone         String
  status        CampaignRecipientStatus @default(PENDING)
  isSent        Boolean                 @default(false)
  runVersion    Int                     @default(0)
  whatsappMsgId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  respondedAt   DateTime?
  clickedAt     DateTime?
  failedReason  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("campaign_recipients")
}

model MessageTemplate {
  id          String       @id @default(uuid())
  businessId  String
  name        String
  content     String
  type        CampaignType @default(MARKETING)
  category    String?
  isSystem    Boolean      @default(false)
  variables   String[]     @default([])
  whatsappTemplateName     String?
  whatsappTemplateLanguage String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([businessId, category])
  @@map("message_templates")
}

model CampaignJourney {
  id          String        @id @default(uuid())
  businessId  String
  name        String
  description String?
  status      JourneyStatus @default(DRAFT)
  triggerType String        @default("MANUAL")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business    Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  steps       CampaignJourneyStep[]
  enrollments CampaignJourneyEnrollment[]
  campaigns   Campaign[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([businessId, status])
  @@map("campaign_journeys")
}

model CampaignJourneyStep {
  id           String   @id @default(uuid())
  journeyId    String
  orderIndex   Int
  delayMinutes Int      @default(0)
  message      String
  messageType  CampaignMessageType @default(TEXT)
  mediaUrl     String?
  templateId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journey CampaignJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, orderIndex])
  @@index([journeyId])
  @@map("campaign_journey_steps")
}

model CampaignJourneyEnrollment {
  id          String                  @id @default(uuid())
  journeyId   String
  businessId  String
  customerId  String
  currentStep Int                     @default(0)
  status      JourneyEnrollmentStatus @default(ACTIVE)
  nextStepAt  DateTime?
  startedAt   DateTime                @default(now())
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  journey  CampaignJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([journeyId, customerId])
  @@index([businessId, status, nextStepAt])
  @@index([customerId])
  @@map("campaign_journey_enrollments")
}

model CustomerCampaignOptOut {
  businessId String
  customerId String @unique
  optedOutAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([businessId, customerId])
  @@index([businessId])
  @@map("customer_campaign_opt_outs")
}

model CustomerImportJob {
  id             String          @id @default(uuid())
  businessId     String
  fileName       String
  fileType       String
  status         ImportJobStatus @default(PENDING)
  totalRows      Int             @default(0)
  importedCount  Int             @default(0)
  duplicateCount Int             @default(0)
  invalidCount   Int             @default(0)
  report         Json?
  createdById    String?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("ImportJobCreator", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([businessId, createdAt])
  @@map("customer_import_jobs")
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────────────────────────

model KnowledgeBase {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]

  @@index([businessId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String         @id @default(uuid())
  knowledgeBaseId String
  title           String
  type            DocumentType
  status          DocumentStatus @default(UPLOADED)
  fileUrl         String?
  fileSize        Int?
  content         String?
  processingError String?
  category        String?
  question        String?
  answer          String?
  embedding       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([knowledgeBaseId])
  @@index([knowledgeBaseId, type])
  @@index([knowledgeBaseId, status])
  @@map("knowledge_documents")
}

// ─── WHATSAPP ────────────────────────────────────────────────────────────────

model WhatsAppAccount {
  id                String   @id @default(uuid())
  businessId        String
  phoneNumberId     String   @unique
  phoneNumber       String
  displayName       String?
  wabaId            String?
  accessToken       String?
  webhookVerified   Boolean  @default(false)
  phoneNumberStatus String?  @default("unknown")
  webhookStatus     String?  @default("pending")
  lastWebhookReceivedAt DateTime?
  lastSyncAt        DateTime?
  lastGraphApiResponse Json?
  lastGraphApiError    Json?
  lastOutgoingAt       DateTime?
  reengagementTemplateName     String?
  reengagementTemplateLanguage String?  @default("en")
  reengagementTemplateHasBodyVariable Boolean @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([businessId])
  @@index([phoneNumberId])
  @@map("whatsapp_accounts")
}

model WhatsAppWebhookEvent {
  id         String   @id @default(uuid())
  eventId    String   @unique
  eventType  String
  businessId String?
  receivedAt DateTime @default(now())

  @@index([receivedAt])
  @@index([businessId])
  @@map("whatsapp_webhook_events")
}

// ─── BUSINESS PROFILE (AI identity — separate from Knowledge Base) ───────────

enum BusinessProfileExtractionStatus {
  NONE
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model BusinessProfile {
  id                  String                          @id @default(uuid())
  businessId          String                          @unique
  businessName        String?
  logoUrl             String?
  businessCategory    String?
  industryLabel       String?
  companyOverview     String?
  aboutUs             String?
  mission             String?
  vision              String?
  coreValues          Json?
  businessDescription String?
  founder             String?
  website             String?
  email               String?
  phone               String?
  whatsapp            String?
  address             String?
  country             String?
  city                String?
  workingHours        String?
  googleMapsUrl       String?
  socialMedia         Json?
  yearsInBusiness     Int?
  certifications      Json?
  awards              Json?
  brandTone           String?
  languages           Json?
  callToAction        String?
  whyChooseUs         String?
  companyIntroduction String?
  companySummary      String?
