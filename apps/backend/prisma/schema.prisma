generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
  RECEPTIONIST
  STAFF
}

enum Industry {
  CLINIC
  HOSPITAL
  HOTEL
  RESTAURANT
  SALON
  UNIVERSITY
  SCHOOL
  TRAVEL_AGENCY
  REAL_ESTATE
  CONSTRUCTION
  ECOMMERCE
  RETAIL
  LOGISTICS
  NGO
  GOVERNMENT
  CONSULTING
  SERVICE_BUSINESS
  OTHER
}

enum SubscriptionPlan {
  FREE
  STARTER
  BUSINESS
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BusinessLicenseStatus {
  PENDING
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
  LOCKED
}

enum SubscriptionDurationPreset {
  DAYS_7
  DAYS_14
  DAYS_30
  DAYS_60
  DAYS_90
  DAYS_180
  DAYS_365
  CUSTOM
}

enum SubscriptionActivityAction {
  ASSIGNED
  EXTENDED
  SHORTENED
  PAUSED
  RESUMED
  SUSPENDED
  REACTIVATED
  EXPIRED
  UNLOCKED
  LOCKED
  RENEWED
  CANCELLED
  UPGRADED
  DOWNGRADED
  NOTE_ADDED
  EDITED
}

enum SubscriptionNotificationType {
  REMINDER_7D
  REMINDER_5D
  REMINDER_3D
  REMINDER_2D
  REMINDER_1D
  REMINDER_12H
  REMINDER_6H
  REMINDER_1H
  EXPIRED
  ACTIVATED
  SUSPENDED
  RENEWED
}

enum SubscriptionPaymentStatus {
  NOT_APPLICABLE
  PENDING
  PAID
  FAILED
  REFUNDED
  MANUAL
  COMPLIMENTARY
  LOCAL_PAYMENT_PENDING
}

enum SubscriptionPaymentMethod {
  CASH
  EVC_PLUS
  ZAAD
  EDAHAB
  PREMIER_WALLET
  BANK
  MANUAL
  STRIPE
}

enum SubscriptionTransactionType {
  PAYMENT
  REFUND
  ADJUSTMENT
  RENEWAL
}

enum SubscriptionTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SubscriptionDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum SubscriptionNotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  PUSH
  IN_APP
}

enum SubscriptionNotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  TEMPLATE
  INTERACTIVE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  MISSED
}

enum AppointmentNotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  PUSH
}

enum AppointmentNotificationType {
  APPOINTMENT_CREATED
  APPOINTMENT_APPROVED
  REMINDER_30_MIN
  REMINDER_20_MIN
  REMINDER_10_MIN
  MISSED_APPOINTMENT
  FOLLOW_UP_24H
}

enum AppointmentNotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum DocumentType {
  PDF
  DOCX
  TXT
  FAQ
}

enum DocumentStatus {
  UPLOADED
  PENDING
  PROCESSING
  INDEXING
  INDEXED
  FAILED
}

enum NotificationType {
  MESSAGE
  APPOINTMENT
  TEAM
  SYSTEM
  BILLING
  REMINDER
  MISSED_APPOINTMENT
  NEW_CUSTOMER
  AI_ESCALATION
  APPOINTMENT_APPROVED
  APPOINTMENT_CANCELLED
  CAMPAIGN_DELIVERED
  CAMPAIGN_FAILED
}

enum CustomerType {
  VIP
  REGULAR
  NEW_CUSTOMER
  RETURNING
  HIGH_VALUE
  PREMIUM
  INACTIVE
  LEAD
  PROSPECT
}

enum AppointmentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum CampaignType {
  PROMOTION
  OFFER
  ANNOUNCEMENT
  REMINDER
  FOLLOW_UP
  HOLIDAY
  MARKETING
  WELCOME
  APPOINTMENT_REMINDER
  BIRTHDAY
  PAYMENT_REMINDER
  INVOICE
  PRODUCT_LAUNCH
  SEASONAL
  DISCOUNT
  RETENTION
  RE_ENGAGEMENT
  THANK_YOU
  CUSTOM
}

enum CampaignSchedule {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  RECURRING
  CUSTOM
}

enum CampaignMessageType {
  TEXT
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  LOCATION
  INTERACTIVE
  TEMPLATE
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JourneyEnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  SENDING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
  ARCHIVED
}

enum CampaignRecipientStatus {
  PENDING
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum WhatsAppStatus {
  CONNECTED
  NOT_CONNECTED
}

model BusinessTypeDefinition {
  id          String   @id
  label       String
  icon        String   @default("📋")
  category    String
  industry    String
  description String
  keywords    String[] @default([])
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("business_type_definitions")
}

// ─── BUSINESS (TENANT) ───────────────────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  industry    Industry @default(OTHER)
  phone       String?
  email       String?
  website     String?
  address     String?
  country     String?
  city        String?
  whatsappNumber String?
  timezone    String   @default("UTC")
  logoUrl     String?
  isActive    Boolean  @default(true)
  onboardingStep Int   @default(0)
  onboardingCompletedAt DateTime?
  onboardingData Json?
  employeeRange String?
  customerVolume String?
  mainGoal    String?
  businessType String?
  businessCategory String?
  whatsappStatus WhatsAppStatus @default(NOT_CONNECTED)
  licenseStatus  BusinessLicenseStatus @default(PENDING)
  isLicenseLocked Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members           BusinessMember[]
  customers         Customer[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  appointments      Appointment[]
  appointmentNotifications AppointmentNotification[]
  services          Service[]
  knowledgeBases    KnowledgeBase[]
  whatsappAccounts  WhatsAppAccount[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  subscription      Subscription?
  businessSubscription BusinessSubscription?
  subscriptionHistory SubscriptionHistory[]
  subscriptionNotifications SubscriptionNotification[]
  subscriptionActivityLogs SubscriptionActivityLog[]
  subscriptionPayments SubscriptionPayment[]
  subscriptionTransactions SubscriptionTransaction[]
  invoices          Invoice[]
  aiConfiguration   AIConfiguration?
  teamInvitations   TeamInvitation[]
  customerSegments  CustomerSegment[]
  campaigns         Campaign[]
  messageTemplates  MessageTemplate[]
  customerImportJobs CustomerImportJob[]
  campaignJourneys  CampaignJourney[]
  campaignOptOuts   CustomerCampaignOptOut[]
  businessProfile   BusinessProfile?
  employees         Employee[]
  employeeGroups    EmployeeGroup[]
  employeeBroadcasts EmployeeBroadcast[]
  employeeTemplates EmployeeTemplate[]
  employeeConversations EmployeeConversation[]
  employeeImportJobs EmployeeImportJob[]

  @@index([slug])
  @@index([isActive])
  @@map("businesses")
}

// ─── USERS & TEAM ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  avatarUrl         String?
  phone             String?
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpires DateTime?
  emailOtpHash      String?
  emailOtpExpires   DateTime?
  emailOtpAttempts  Int       @default(0)
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  resetOtpHash      String?
  resetOtpExpires   DateTime?
  resetOtpAttempts  Int       @default(0)
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  isSuperAdmin      Boolean   @default(false)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  totpBackupCodes   String?
  welcomeSeenAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  businessMemberships BusinessMember[]
  refreshTokens       RefreshToken[]
  sentMessages        Message[]          @relation("SentByUser")
  assignedConversations Conversation[]   @relation("AssignedAgent")
  assignedAppointments Appointment[]     @relation("AssignedStaff")
  appointmentNotes    AppointmentInternalNote[] @relation("AppointmentNoteAuthor")
  createdAppointments Appointment[]           @relation("AppointmentCreator")
  createdCampaigns    Campaign[]              @relation("CampaignCreator")
  createdEmployeeBroadcasts EmployeeBroadcast[] @relation("EmployeeBroadcastCreator")
  employees           Employee[]
  createdImportJobs   CustomerImportJob[]     @relation("ImportJobCreator")
  createdEmployeeImportJobs EmployeeImportJob[] @relation("EmployeeImportJobCreator")
  ownedEmployeeGroups EmployeeGroup[]         @relation("EmployeeGroupOwner")
  auditLogs           AuditLog[]
  notifications       Notification[]
  assignedSubscriptions BusinessSubscription[] @relation("SubscriptionAssignedBy")
  subscriptionHistoryEntries SubscriptionHistory[] @relation("SubscriptionHistoryPerformedBy")
  subscriptionActivityEntries SubscriptionActivityLog[] @relation("SubscriptionActivityPerformedBy")
  recordedSubscriptionPayments SubscriptionPayment[] @relation("SubscriptionPaymentRecordedBy")
  subscriptionRenewals SubscriptionRenewal[] @relation("SubscriptionRenewalBy")
  appliedSubscriptionDiscounts SubscriptionDiscount[] @relation("SubscriptionDiscountAppliedBy")

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  role       UserRole @default(AGENT)
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([role])
  @@map("business_members")
}

model TeamInvitation {
  id         String   @id @default(uuid())
  businessId String
  email      String
  role       UserRole @default(AGENT)
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── CUSTOMERS (CRM) ─────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid())
  businessId    String
  name          String
  phone         String
  email         String?
  whatsappId    String?
  whatsappNumber String?
  companyName   String?
  address       String?
  city          String?
  country       String?
  notes         String?
  source        String?
  customerType  CustomerType @default(REGULAR)
  leadStatus    LeadStatus   @default(NEW)
  leadScore     Int          @default(0)
  customerValue Decimal?     @db.Decimal(12, 2)
  aiSummary     Json?
  isActive      Boolean      @default(true)
  lastContactAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business      Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tags          CustomerTagAssignment[]
  conversations Conversation[]
  appointments  Appointment[]
  appointmentNotifications AppointmentNotification[]
  customerNotes CustomerNote[]
  segmentMembers CustomerSegmentMember[]
  campaignRecipients CampaignRecipient[]
  targetedCampaigns Campaign[] @relation("CampaignTargetCustomer")
  journeyEnrollments CampaignJourneyEnrollment[]
  campaignOptOut     CustomerCampaignOptOut?

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, email])
  @@index([businessId, lastContactAt])
  @@index([whatsappId])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  color      String   @default("#651147")
  createdAt  DateTime @default(now())

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers CustomerTagAssignment[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  assignedAt DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  content    String
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

// ─── CONVERSATIONS & MESSAGES ────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(uuid())
  businessId      String
  customerId      String
  whatsappAccountId String?
  status          ConversationStatus @default(OPEN)
  assignedToId    String?
  isAiEnabled     Boolean            @default(true)
  isTyping        Boolean            @default(false)
  unreadCount     Int                @default(0)
  lastMessageAt   DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id])
  assignedTo      User?            @relation("AssignedAgent", fields: [assignedToId], references: [id])
  messages        Message[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([businessId, assignedToId])
  @@index([businessId, customerId, status])
  @@index([customerId])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  mediaUrl       String?
  whatsappMsgId  String?          @unique
  status         MessageStatus    @default(PENDING)
  isAiGenerated  Boolean          @default(false)
  sentByUserId   String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("SentByUser", fields: [sentByUserId], references: [id])

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([whatsappMsgId])
  @@index([direction])
  @@map("messages")
}

// ─── APPOINTMENTS & SERVICES ─────────────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  duration    Int      @default(30)
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, isActive])
  @@map("services")
}

model Appointment {
  id                     String              @id @default(uuid())
  businessId             String
  customerId             String
  serviceId              String?
  assignedToId           String?
  createdById            String?
  title                  String
  description            String?
  serviceRequested       String?
  serviceCategory        String?
  companyName            String?
  additionalNotes        String?
  requirementsCollected  Json?
  aiConversationSummary  Json?
  budget                 Decimal?            @db.Decimal(12, 2)
  leadSource             String?             @default("WHATSAPP")
  meetingLink            String?
  priority               AppointmentPriority @default(MEDIUM)
  startTime              DateTime
  endTime                DateTime
  status                 AppointmentStatus   @default(SCHEDULED)
  rejectionReason        String?
  notes                  String?
  reminderSent           Boolean             @default(false)
  reminder24hSent        Boolean             @default(false)
  reminder1hSent         Boolean             @default(false)
  reminder15mSent        Boolean             @default(false)
  reminder30mSent        Boolean             @default(false)
  reminder20mSent        Boolean             @default(false)
  reminder10mSent        Boolean             @default(false)
  followUp24hSent        Boolean             @default(false)
  missedNotificationSent Boolean             @default(false)
  confirmationSentAt     DateTime?
  missedAt               DateTime?
  canRebookAfter         DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service       Service?                  @relation(fields: [serviceId], references: [id])
  assignedTo    User?                     @relation("AssignedStaff", fields: [assignedToId], references: [id])
  createdBy     User?                     @relation("AppointmentCreator", fields: [createdById], references: [id])
  internalNotes AppointmentInternalNote[]
  notifications AppointmentNotification[]

  @@index([businessId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([priority])
  @@map("appointments")
}

model AppointmentInternalNote {
  id            String   @id @default(uuid())
  appointmentId String
  content       String
  createdById   String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("AppointmentNoteAuthor", fields: [createdById], references: [id])

  @@index([appointmentId])
  @@map("appointment_internal_notes")
}

model AppointmentNotification {
  id               String                       @id @default(uuid())
  appointmentId    String
  businessId       String
  customerId       String
  channel          AppointmentNotificationChannel
  notificationType AppointmentNotificationType
  scheduledAt      DateTime?
  sentAt           DateTime?
  status           AppointmentNotificationStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime                     @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, notificationType, channel])
  @@index([appointmentId])
  @@index([businessId, status])
  @@index([scheduledAt, status])
  @@map("appointment_notifications")
}

// ─── CUSTOMER SEGMENTS & CAMPAIGNS ───────────────────────────────────────────

model CustomerSegment {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#D97706")
  customerType CustomerType?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  members   CustomerSegmentMember[]
  campaigns Campaign[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_segments")
}

model CustomerSegmentMember {
  segmentId  String
  customerId String
  addedAt    DateTime @default(now())

  segment  CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([segmentId, customerId])
  @@index([customerId])
  @@map("customer_segment_members")
}

model Campaign {
  id               String              @id @default(uuid())
  businessId       String
  name             String
  message          String
  type             CampaignType        @default(MARKETING)
  schedule         CampaignSchedule    @default(ONE_TIME)
  status           CampaignStatus      @default(DRAFT)
  messageType      CampaignMessageType @default(TEXT)
  segmentId        String?
  templateId       String?
  customerTypes    CustomerType[]
  sendToAll        Boolean             @default(false)
  targetCustomerId String?
  isSent           Boolean             @default(false)
  runVersion       Int                 @default(0)
  scheduledAt      DateTime?
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  timezone         String?
  cronExpression   String?
  scheduleConfig   Json?
  repeatCount      Int?
  repeatUntil      DateTime?
  runsCompleted    Int                 @default(0)
  mediaUrl         String?
  mediaFilename    String?
  category         String?
  journeyId        String?
  createdById      String?
  sentCount        Int                 @default(0)
  deliveredCount   Int                 @default(0)
  failedCount      Int                 @default(0)
  readCount        Int                 @default(0)
  responseCount    Int                 @default(0)
  linkClickCount   Int                 @default(0)
  optOutCount      Int                 @default(0)
  blockedCount     Int                 @default(0)
  archivedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  segment        CustomerSegment?    @relation(fields: [segmentId], references: [id])
  template       MessageTemplate?    @relation(fields: [templateId], references: [id])
  targetCustomer Customer?           @relation("CampaignTargetCustomer", fields: [targetCustomerId], references: [id])
  journey        CampaignJourney?    @relation(fields: [journeyId], references: [id])
  createdBy      User?               @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients     CampaignRecipient[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([scheduledAt])
  @@index([nextRunAt])
  @@index([templateId])
  @@index([targetCustomerId])
  @@index([journeyId])
  @@map("campaigns")
}

model CampaignRecipient {
  id            String                  @id @default(uuid())
  campaignId    String
  customerId    String
  phone         String
  status        CampaignRecipientStatus @default(PENDING)
  isSent        Boolean                 @default(false)
  runVersion    Int                     @default(0)
  whatsappMsgId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  respondedAt   DateTime?
  clickedAt     DateTime?
  failedReason  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
