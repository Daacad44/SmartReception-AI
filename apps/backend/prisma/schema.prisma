generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum Industry {
  CLINIC
  HOSPITAL
  HOTEL
  RESTAURANT
  SALON
  UNIVERSITY
  TRAVEL_AGENCY
  REAL_ESTATE
  CONSULTING
  SERVICE_BUSINESS
  OTHER
}

enum SubscriptionPlan {
  FREE
  STARTER
  BUSINESS
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  TEMPLATE
  INTERACTIVE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum DocumentType {
  PDF
  DOCX
  TXT
  FAQ
}

enum DocumentStatus {
  UPLOADED
  PENDING
  PROCESSING
  INDEXING
  INDEXED
  FAILED
}

enum NotificationType {
  MESSAGE
  APPOINTMENT
  TEAM
  SYSTEM
  BILLING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

// ─── BUSINESS (TENANT) ───────────────────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  industry    Industry @default(OTHER)
  phone       String?
  email       String?
  website     String?
  address     String?
  timezone    String   @default("UTC")
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members           BusinessMember[]
  customers         Customer[]
  customerTags      CustomerTag[]
  conversations     Conversation[]
  appointments      Appointment[]
  services          Service[]
  knowledgeBases    KnowledgeBase[]
  whatsappAccounts  WhatsAppAccount[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  subscription      Subscription?
  invoices          Invoice[]
  aiConfiguration   AIConfiguration?
  teamInvitations   TeamInvitation[]

  @@index([slug])
  @@index([isActive])
  @@map("businesses")
}

// ─── USERS & TEAM ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  avatarUrl         String?
  phone             String?
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpires DateTime?
  emailOtpHash      String?
  emailOtpExpires   DateTime?
  emailOtpAttempts  Int       @default(0)
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  resetOtpHash      String?
  resetOtpExpires   DateTime?
  resetOtpAttempts  Int       @default(0)
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  businessMemberships BusinessMember[]
  refreshTokens       RefreshToken[]
  sentMessages        Message[]          @relation("SentByUser")
  assignedConversations Conversation[]   @relation("AssignedAgent")
  auditLogs           AuditLog[]
  notifications       Notification[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  role       UserRole @default(AGENT)
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([role])
  @@map("business_members")
}

model TeamInvitation {
  id         String   @id @default(uuid())
  businessId String
  email      String
  role       UserRole @default(AGENT)
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── CUSTOMERS (CRM) ─────────────────────────────────────────────────────────

model Customer {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  phone        String
  email        String?
  whatsappId   String?
  notes        String?
  source       String?
  leadScore    Int      @default(0)
  isActive     Boolean  @default(true)
  lastContactAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tags          CustomerTagAssignment[]
  conversations Conversation[]
  appointments  Appointment[]
  customerNotes CustomerNote[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, email])
  @@index([businessId, lastContactAt])
  @@index([whatsappId])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  color      String   @default("#651147")
  createdAt  DateTime @default(now())

  business  Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers CustomerTagAssignment[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  assignedAt DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  content    String
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

// ─── CONVERSATIONS & MESSAGES ────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(uuid())
  businessId      String
  customerId      String
  whatsappAccountId String?
  status          ConversationStatus @default(OPEN)
  assignedToId    String?
  isAiEnabled     Boolean            @default(true)
  isTyping        Boolean            @default(false)
  unreadCount     Int                @default(0)
  lastMessageAt   DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id])
  assignedTo      User?            @relation("AssignedAgent", fields: [assignedToId], references: [id])
  messages        Message[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, lastMessageAt])
  @@index([customerId])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  mediaUrl       String?
  whatsappMsgId  String?          @unique
  status         MessageStatus    @default(PENDING)
  isAiGenerated  Boolean          @default(false)
  sentByUserId   String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("SentByUser", fields: [sentByUserId], references: [id])

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([whatsappMsgId])
  @@index([direction])
  @@map("messages")
}

// ─── APPOINTMENTS & SERVICES ─────────────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  duration    Int      @default(30)
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, isActive])
  @@map("services")
}

model Appointment {
  id          String            @id @default(uuid())
  businessId  String
  customerId  String
  serviceId   String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  reminderSent Boolean          @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service?  @relation(fields: [serviceId], references: [id])

  @@index([businessId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([customerId])
  @@map("appointments")
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────────────────────────

model KnowledgeBase {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]

  @@index([businessId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String         @id @default(uuid())
  knowledgeBaseId String
  title           String
  type            DocumentType
  status          DocumentStatus @default(UPLOADED)
  fileUrl         String?
  fileSize        Int?
  content         String?
  processingError String?
  category        String?
  question        String?
  answer          String?
  embedding       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([knowledgeBaseId, type])
  @@index([knowledgeBaseId, status])
  @@map("knowledge_documents")
}

// ─── WHATSAPP ────────────────────────────────────────────────────────────────

model WhatsAppAccount {
  id                String   @id @default(uuid())
  businessId        String
  phoneNumberId     String   @unique
  phoneNumber       String
  displayName       String?
  wabaId            String?
  accessToken       String?
  webhookVerified   Boolean  @default(false)
  phoneNumberStatus String?  @default("unknown")
  webhookStatus     String?  @default("pending")
  lastSyncAt        DateTime?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([businessId])
  @@index([phoneNumberId])
  @@map("whatsapp_accounts")
}

model WhatsAppWebhookEvent {
  id         String   @id @default(uuid())
  eventId    String   @unique
  eventType  String
  businessId String?
  receivedAt DateTime @default(now())

  @@index([receivedAt])
  @@index([businessId])
  @@map("whatsapp_webhook_events")
}

// ─── AI CONFIGURATION ────────────────────────────────────────────────────────

model AIConfiguration {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  systemPrompt          String?
  temperature           Float    @default(0.7)
  maxTokens             Int      @default(500)
  enableAutoReply       Boolean  @default(true)
  enableBooking         Boolean  @default(true)
  enableLeadQualification Boolean @default(true)
  languages             String[] @default(["en"])
  greetingMessage       String?
  fallbackMessage       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("ai_configurations")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  businessId String
  userId     String?
  type       NotificationType
  title      String
  message    String
  data       Json?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([businessId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  businessId String?
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── BILLING ─────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  businessId           String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

model Invoice {
  id              String        @id @default(uuid())
  businessId      String
  invoiceNumber   String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          InvoiceStatus @default(DRAFT)
  stripeInvoiceId String?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}
